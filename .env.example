# ============================================================
#  aequilibri POC — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
#  On Render: set these in the Environment tab of the dashboard.
# ============================================================

# ── Django Core ─────────────────────────────────────────────
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# On Render this is auto-generated via render.yaml (generateValue: true)
DJANGO_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_STRING

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of hostnames that can serve the app
# Local: localhost,127.0.0.1
# Render: .onrender.com  (or your custom domain)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# HTTPS origins allowed to make cross-site POST requests (Django CSRF)
# Render sets this automatically via render.yaml
CSRF_TRUSTED_ORIGINS=https://yourapp.onrender.com

# ── Database ─────────────────────────────────────────────────
# Leave blank for local SQLite.
# Render injects this automatically from the managed PostgreSQL database.
DATABASE_URL=

# ── Google API Keys ──────────────────────────────────────────
# One key that has Maps JS, Places, Geocoding, and Solar APIs enabled.
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
GOOGLE_SOLAR_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── Anthropic (Claude AI) ────────────────────────────────────
# Get from: https://console.anthropic.com/
# Leave blank to run in demo mode (no AI features)
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY

# ── Geoscape Australia ───────────────────────────────────────
# Building footprint and roof attribute API
GEOSCAPE_CONSUMER_KEY=YOUR_GEOSCAPE_CONSUMER_KEY
GEOSCAPE_CONSUMER_SECRET=YOUR_GEOSCAPE_CONSUMER_SECRET

# ── Local Server Port (Windows / Waitress only) ──────────────
APP_PORT=8000
